# HTTP bind (optional). Default :8080 if unset.
# Use one of:
#   HTTP_ADDR=:9090
#   HTTP_PORT=9090
#   PORT=9090
# HTTP_ADDR=
# HTTP_PORT=

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bebii_seo_dashboard

# Optional shared token between plugin and verification API
PLUGIN_SHARED_TOKEN=

# Required if plugin sends encrypted x-digital header
BEBII_GLOBAL_KEY=

# --- Production Nginx (optional): long-running POST /dashboard/blogs/add-domain ---
# Default proxy_read_timeout is often 60s; add.sh + SSL can take longer. Example:
#   proxy_connect_timeout 600s;
#   proxy_send_timeout 3600s;
#   proxy_read_timeout 3600s;
#   send_timeout 3600s;
# Cloudflare proxied mode often limits ~100s; use DNS-only for this hostname or Enterprise.


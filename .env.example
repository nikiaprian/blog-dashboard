# HTTP bind (optional). Default :8080 if unset.
# Use one of:
#   HTTP_ADDR=:9090
#   HTTP_PORT=9090
#   PORT=9090
# HTTP_ADDR=
# HTTP_PORT=

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bebii_seo_dashboard

# Optional shared token between plugin and verification API
PLUGIN_SHARED_TOKEN=

# Required if plugin sends encrypted x-digital header
BEBII_GLOBAL_KEY=

# --- Production Nginx: required for long-running SSH (same fix for all below) ---
# Default proxy_read_timeout is often 60s → 504 Gateway Timeout while Go still runs.
# Applies to: POST /dashboard/blogs/add-domain (add.sh), POST /admin/servers/run-update (update.sh).
# Copy lines from deploy/nginx-proxy-timeouts.conf.example into your server { } block.
# Cloudflare orange-cloud often limits ~100s; prefer DNS-only for this hostname or Enterprise.

# --- Remote add.sh (Tambah Domain): Git clone credentials from dashboard .env ---
# When set, SSH runs: sudo env GITHUB_TOKEN=... GITHUB_USERNAME=... [GIT_URL=...] /home/add.sh
# so blog servers do not need /root/.github_token. Matches add.sh env vars GIT_URL, GITHUB_*.
# PAT: set ADD_GITHUB_USERNAME=x-access-token (default if omitted) or your GitHub username.
# ADD_GITHUB_TOKEN=
# ADD_GITHUB_USERNAME=
# ADD_GIT_URL=https://github.com/Bebii-Digital/bebii-blog.git


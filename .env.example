# HTTP bind (optional). Default :8080 if unset.
# Use one of:
#   HTTP_ADDR=:9090
#   HTTP_PORT=9090
#   PORT=9090
# HTTP_ADDR=
# HTTP_PORT=

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bebii_seo_dashboard

# Optional shared token between plugin and verification API
PLUGIN_SHARED_TOKEN=

# --- Artifact registry (zip / tar.gz) ---
# Files on disk under REGISTRY_ROOT. Admin UI: /admin/registry (login admin).
# API upload (GitHub Actions): POST /api/registry/{artifact} + REGISTRY_UPLOAD_TOKEN
# API download: GET /api/registry/{artifact}/manifest | /latest | /{version}/{file}
# REGISTRY_ROOT=data/registry
# REGISTRY_UPLOAD_TOKEN=generate-a-long-random-secret
# REGISTRY_READ_TOKEN=optional; if set, download API requires same header as upload

# Required if plugin sends encrypted x-digital header
BEBII_GLOBAL_KEY=

# --- Production Nginx: required for long-running SSH (same fix for all below) ---
# Default proxy_read_timeout is often 60s → 504 Gateway Timeout while Go still runs.
# Applies to: POST /dashboard/blogs/add-domain (add.sh), POST /admin/servers/run-update,
#   POST /dashboard/servers/run-update (update.sh, user’s linked servers only).
# Copy lines from deploy/nginx-proxy-timeouts.conf.example into your server { } block.
# Cloudflare orange-cloud often limits ~100s; prefer DNS-only for this hostname or Enterprise.

# --- Remote add.sh / update.sh: Git credentials from dashboard .env ---
# When ADD_GITHUB_TOKEN is set, SSH runs: sudo -n env GITHUB_TOKEN=... GITHUB_USERNAME=... [GIT_URL=...] <script>
# for /home/add.sh (tambah domain) and /home/update.sh --all (admin Run update). Matches GIT_URL, GITHUB_* on the remote.
# so blog servers do not need /root/.github_token.
# PAT: set ADD_GITHUB_USERNAME=x-access-token (default if omitted) or your GitHub username.
# ADD_GITHUB_TOKEN=
# ADD_GITHUB_USERNAME=
# ADD_GIT_URL=https://github.com/Bebii-Digital/bebii-blog.git

# --- User dashboard: banner when main branch has new commits (GitHub API) ---
# Uses ADD_GITHUB_TOKEN, or set GITHUB_TOKEN for API-only. Needs repo read scope.
# Optional override (default Bebii-Digital/bebii-blog, branch main in code).
# BEBII_BLOG_REPO=Bebii-Digital/bebii-blog

